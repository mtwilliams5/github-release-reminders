# Set IS_LOCAL=true to read secrets from environment variables instead of SSM
IS_LOCAL=true

# Comma-separated list of GitHub repositories to check (owner/repo format)
REPOSITORIES=my-org/my-repo,my-org/another-repo

# Jira ticket pattern regex (default: \w+-\d+)
# TICKET_PATTERN=PROJ-\\d+

# Comma-separated Jira statuses that indicate a ticket is ready to deploy
# READY_STATUSES=Ready to Deploy

# Comma-separated Jira statuses that indicate a ticket is in QA
# QA_STATUSES=In QA

# --- Secrets (required) ---

# GitHub personal access token with repo read access
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Jira credentials
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USER_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token

# Slack bot token and channel ID
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_CHANNEL_ID=C0000000000
