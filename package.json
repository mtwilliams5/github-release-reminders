{
  "name": "github-release-reminders",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "jest",
    "lint": "eslint 'src/**/*.ts' 'infra/**/*.ts'",
    "deploy": "yarn build && cdk deploy",
    "diff": "yarn build && cdk diff",
    "sync:agent-instructions": "node scripts/sync-agent-instructions.js",
    "prestart": "yarn build",
    "start": "node dist/src/handler.js"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.700.0",
    "@octokit/rest": "^21.1.0",
    "@slack/web-api": "7.15.0",
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.12.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "aws-cdk": "^2.180.0",
    "esbuild": "0.27.4",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0"
  }
}
