{
  "name": "github-release-reminders",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "jest",
    "lint": "eslint 'src/**/*.ts' 'infra/**/*.ts'",
    "deploy": "yarn build && cdk deploy",
    "diff": "yarn build && cdk diff",
    "sync:agent-instructions": "node scripts/sync-agent-instructions.js",
    "prestart": "yarn build",
    "start": "node dist/src/handler.js"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.1037.0",
    "@octokit/rest": "^22.0.1",
    "@slack/web-api": "7.15.1",
    "aws-cdk-lib": "^2.251.0",
    "constructs": "^10.6.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "aws-cdk": "^2.1119.0",
    "esbuild": "0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.31.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
